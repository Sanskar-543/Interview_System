# Node Environment
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Security (JWT Auth) — MUST be at least 32 characters (no default fallback)
JWT_SECRET=your_jwt_secret_must_be_at_least_32_characters_long

# Persistent Storage
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interviewer
REDIS_URL=redis://localhost:6379

# Conversational AI (Deepgram & OpenRouter)
# Deepgram is used for both speech-to-text (STT) transcribing and text-to-speech (TTS) synthesis.
DEEPGRAM_API_KEY=your_deepgram_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Billing & Monetization (Razorpay) - Optional/Required for SaaS Features
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Network / Gateway Configuration
# CORS_ORIGIN specifies the allowed origins (typically the frontend URL)
CORS_ORIGIN=http://localhost:3000
# VOICE_SERVICE_URL specifies the target URL for the gateway websocket proxy (defaults to ws://localhost:5001)
VOICE_SERVICE_URL=ws://localhost:5001

# Next.js Client-Side Configuration (Loaded on frontend)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000
