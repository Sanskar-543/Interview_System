# Server Ingress Settings
PORT=5000
NODE_ENV=development

# Redis Cache connection string
REDIS_URL=redis://localhost:6379

# Neon Postgres Database URL
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interviewer

# JWT Secret — MUST be at least 32 characters (no default fallback)
JWT_SECRET=your_jwt_secret_must_be_at_least_32_characters_long

# Deepgram Speech-To-Text API key
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OpenRouter Large Language Model API key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Text-To-Speech configuration
# Either set an API key for REST access:
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here
# Or provide the path to your service account credentials:
GOOGLE_APPLICATION_CREDENTIALS=

# Next.js public API URL
NEXT_PUBLIC_API_URL=http://localhost:5000
