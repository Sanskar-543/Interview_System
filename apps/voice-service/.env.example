# Voice Service Port (In development, listens on PORT+1. In production, listens on PORT)
PORT=5000

# Conversational AI Loop Keys (Used for STT, LLM, and TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Persistent Storage & Session Cache
REDIS_URL=redis://localhost:6379

# Wakeup Routing for Worker
WORKER_URL=http://localhost:8000

# Required by shared validation schema at startup (Even if not directly read by voice-service code)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interviewer
JWT_SECRET=your_secure_32_character_jwt_secret_here

# Environment Mode
NODE_ENV=development
LOG_LEVEL=info
