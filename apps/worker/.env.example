# Worker HTTP Server Port (Used for Render wake-up pings and health checks)
PORT=8000

# Persistent Storage & BullMQ Queue connection
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interviewer
REDIS_URL=redis://localhost:6379

# Evaluation LLM calls (Llama-3 model via OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required by shared validation schema at startup (Even if not directly read by worker code)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
JWT_SECRET=your_secure_32_character_jwt_secret_here

# Environment Mode
NODE_ENV=development
LOG_LEVEL=info
